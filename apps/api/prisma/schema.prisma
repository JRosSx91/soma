generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum BiologicalSex {
  male
  female
}

enum SubstanceCategory {
  depressant
  stimulant
  cannabinoid
  nicotine
  opioid
  hallucinogen
  dissociative
}

enum UsageFrequency {
  daily
  weekly
  monthly
  occasional
}

enum BodySystem {
  respiratory
  cardiovascular
  hepatic
  renal
  nervous_central
  nervous_peripheral
  endocrine
  reproductive
  digestive
  immune
  integumentary
}

enum RecoveryCurveShape {
  logarithmic
  sigmoidal
  linear
  stepwise
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum AchievementTier {
  bronze
  silver
  gold
  platinum
}

// -----------------------------------------------------------------------------
// User domain
// -----------------------------------------------------------------------------

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  hashedPassword String
  displayName    String
  biologicalSex  BiologicalSex
  birthYear      Int
  weightKg       Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  usages         SubstanceUsage[]

  @@index([email])
}

// -----------------------------------------------------------------------------
// Substance catalog
// -----------------------------------------------------------------------------

model Substance {
  id               String            @id
  name             String
  category         SubstanceCategory
  shortDescription String

  usages           SubstanceUsage[]
  damageProfiles   OrganDamageProfile[]
  recoveryCurves   OrganRecoveryCurve[]
  achievements     Achievement[]
}

model SubstanceUsage {
  id           String         @id @default(cuid())
  userId       String
  substanceId  String
  yearStarted  Int
  lastUseDate  DateTime
  frequency    UsageFrequency
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  substance    Substance      @relation(fields: [substanceId], references: [id])

  @@index([userId])
  @@index([substanceId])
}

// -----------------------------------------------------------------------------
// Physiological model
// -----------------------------------------------------------------------------

model Organ {
  id               String     @id
  name             String
  system           BodySystem
  shortDescription String

  damageProfiles   OrganDamageProfile[]
  recoveryCurves   OrganRecoveryCurve[]
  achievements     Achievement[]
}

model OrganDamageProfile {
  id              String          @id @default(cuid())
  organId         String
  substanceId     String
  maxSeverity     Float
  confidenceLevel ConfidenceLevel
  referenceSource String

  organ           Organ           @relation(fields: [organId], references: [id])
  substance       Substance       @relation(fields: [substanceId], references: [id])

  @@unique([organId, substanceId])
  @@index([substanceId])
}

model OrganRecoveryCurve {
  id               String             @id @default(cuid())
  organId          String
  substanceId      String
  shape            RecoveryCurveShape
  daysTo95Recovery Int
  recoveryCeiling  Float
  confidenceLevel  ConfidenceLevel
  referenceSource  String

  organ            Organ              @relation(fields: [organId], references: [id])
  substance        Substance          @relation(fields: [substanceId], references: [id])

  @@unique([organId, substanceId])
  @@index([substanceId])
}

// -----------------------------------------------------------------------------
// Achievements
// -----------------------------------------------------------------------------

model Achievement {
  id                        String          @id
  tier                      AchievementTier
  title                     String
  physiologicalDescription  String
  triggerOrganId            String
  triggerSubstanceId        String
  triggerRecoveryThreshold  Float

  triggerOrgan              Organ           @relation(fields: [triggerOrganId], references: [id])
  triggerSubstance          Substance       @relation(fields: [triggerSubstanceId], references: [id])

  @@index([triggerSubstanceId])
  @@index([triggerOrganId])
}