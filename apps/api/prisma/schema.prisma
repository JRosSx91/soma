generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum BiologicalSex {
  male
  female
}

enum SubstanceCategory {
  depressant
  stimulant
  cannabinoid
  nicotine
  opioid
  hallucinogen
  dissociative
}

enum UsageFrequency {
  daily
  weekly
  monthly
  occasional
}

enum BodySystem {
  respiratory
  cardiovascular
  hepatic
  renal
  nervous_central
  nervous_peripheral
  endocrine
  reproductive
  digestive
  immune
  integumentary
}

enum RecoveryCurveShape {
  logarithmic
  sigmoidal
  linear
  stepwise
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum Neurotransmitter {
  dopamine
  serotonin
  gaba
  glutamate
  acetylcholine
  norepinephrine
  endocannabinoid
  endorphin
  adenosine
}

enum WithdrawalPhase {
  during_use
  acute_withdrawal
  post_acute
  normalizing
}

enum NeurotransmitterDirection {
  depleted
  elevated
  oscillating
  normalizing
}

enum NeurotransmitterSeverity {
  severe
  moderate
  mild
  normalizing
}

enum AchievementTier {
  bronze
  silver
  gold
  platinum
}

// -----------------------------------------------------------------------------
// User domain
// -----------------------------------------------------------------------------

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  hashedPassword String
  displayName    String
  biologicalSex  BiologicalSex
  birthYear      Int
  weightKg       Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  usages         SubstanceUsage[]
  achievements   UserAchievement[]

  @@index([email])
}

// -----------------------------------------------------------------------------
// Substance catalog
// -----------------------------------------------------------------------------

model Substance {
  id                       String            @id
  name                     String
  category                 SubstanceCategory
  shortDescription         String

  usages                   SubstanceUsage[]
  damageProfiles           OrganDamageProfile[]
  recoveryCurves           OrganRecoveryCurve[]
  achievements             Achievement[]
  neurotransmitterProfiles NeurotransmitterProfile[]
  narrativeProfiles        OrganNarrativeProfile[]
}

model SubstanceUsage {
  id           String         @id @default(cuid())
  userId       String
  substanceId  String
  yearStarted  Int
  lastUseDate  DateTime
  frequency    UsageFrequency
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  substance    Substance      @relation(fields: [substanceId], references: [id])

  @@index([userId])
  @@index([substanceId])
}

// -----------------------------------------------------------------------------
// Physiological model
// -----------------------------------------------------------------------------

model Organ {
  id                 String     @id
  name               String
  system             BodySystem
  shortDescription   String

  damageProfiles     OrganDamageProfile[]
  recoveryCurves     OrganRecoveryCurve[]
  achievements       Achievement[]
  narrativeProfiles  OrganNarrativeProfile[]
}

model OrganDamageProfile {
  id              String          @id @default(cuid())
  organId         String
  substanceId     String
  maxSeverity     Float
  confidenceLevel ConfidenceLevel
  referenceSource String

  organ           Organ           @relation(fields: [organId], references: [id])
  substance       Substance       @relation(fields: [substanceId], references: [id])

  @@unique([organId, substanceId])
  @@index([substanceId])
}

model OrganRecoveryCurve {
  id               String             @id @default(cuid())
  organId          String
  substanceId      String
  shape            RecoveryCurveShape
  daysTo95Recovery Int
  recoveryCeiling  Float
  confidenceLevel  ConfidenceLevel
  referenceSource  String

  organ            Organ              @relation(fields: [organId], references: [id])
  substance        Substance          @relation(fields: [substanceId], references: [id])

  @@unique([organId, substanceId])
  @@index([substanceId])
}

// -----------------------------------------------------------------------------
// Achievements
// -----------------------------------------------------------------------------

model Achievement {
  id                        String          @id
  tier                      AchievementTier
  title                     String
  physiologicalDescription  String
  triggerOrganId            String
  triggerSubstanceId        String
  triggerRecoveryThreshold  Float

  triggerOrgan              Organ           @relation(fields: [triggerOrganId], references: [id])
  triggerSubstance          Substance       @relation(fields: [triggerSubstanceId], references: [id])
  unlockedBy                UserAchievement[]

  @@index([triggerSubstanceId])
  @@index([triggerOrganId])
}

// -----------------------------------------------------------------------------
// Neurotransmitter model
// -----------------------------------------------------------------------------

model NeurotransmitterProfile {
  id               String                  @id @default(cuid())
  substanceId      String
  neurotransmitter Neurotransmitter
  confidenceLevel  ConfidenceLevel
  referenceSource  String

  substance        Substance               @relation(fields: [substanceId], references: [id])
  phases           NeurotransmitterPhase[]

  @@unique([substanceId, neurotransmitter])
  @@index([substanceId])
}

model NeurotransmitterPhase {
  id          String                    @id @default(cuid())
  profileId   String
  phase       WithdrawalPhase

  // Inclusive day boundaries from last-use date.
  // endDay is null for the final phase (normalizing continues
  // open-endedly until baseline is approximated).
  startDay    Int
  endDay      Int?

  severity    NeurotransmitterSeverity
  direction   NeurotransmitterDirection

  // i18n key under the `neurotransmitter-phases` namespace.
  // Format: <substanceId>.<neurotransmitter>.<phase>
  // Example: cocaine.dopamine.acute_withdrawal
  symptomKey  String

  profile     NeurotransmitterProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// -----------------------------------------------------------------------------
// Organ narrative model
// -----------------------------------------------------------------------------
//
// Describes the cellular/tissue-level recovery process for non-neural
// organs. Unlike neurotransmitters, these narratives focus on observable
// physiological processes (cilia movement, tissue regeneration, mucosa
// healing) rather than subjective experience.
//
// Reuses the WithdrawalPhase enum from the neurotransmitter model.

model OrganNarrativeProfile {
  id              String                 @id @default(cuid())
  organId         String
  substanceId     String
  confidenceLevel ConfidenceLevel
  referenceSource String

  organ           Organ                  @relation(fields: [organId], references: [id])
  substance       Substance              @relation(fields: [substanceId], references: [id])
  phases          OrganNarrativePhase[]

  @@unique([organId, substanceId])
  @@index([organId])
  @@index([substanceId])
}

model OrganNarrativePhase {
  id          String                  @id @default(cuid())
  profileId   String
  phase       WithdrawalPhase

  // Inclusive day boundaries from last-use date.
  // endDay is null for the final (normalizing) phase.
  startDay    Int
  endDay      Int?

  // i18n key under the `organ-narrative` namespace.
  // Format: <organId>.<substanceId>.<phase>
  // Example: lungs.nicotine.acute_withdrawal
  narrativeKey String

  profile     OrganNarrativeProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// -----------------------------------------------------------------------------
// User achievements
// -----------------------------------------------------------------------------
//
// Persisted record of which achievements a user has unlocked, when, and
// whether they have been notified about it. Calculated on-demand when
// the user queries /me/achievements; new unlocks are inserted, existing
// rows are not modified.
//
// `unlockedAt` reflects the actual date the recovery threshold was
// crossed (computed by inverting the recovery curve from the user's
// lastUseDate), not the time of detection.
//
// `notifiedAt` is null until the frontend (web) or push system (mobile)
// surfaces the achievement to the user. PR 17 will set it.

model UserAchievement {
  id              String      @id @default(cuid())
  userId          String
  achievementId   String

  // The actual date the user crossed the recovery threshold.
  unlockedAt      DateTime

  // Null until the user has been notified of this unlock.
  // Set by frontend (web batch toast) or push notification system.
  notifiedAt      DateTime?

  createdAt       DateTime    @default(now())

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([userId, notifiedAt])
}